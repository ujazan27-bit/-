import java.util.Arrays;
import java.util.Stack;
class Graph {
 private int vertices;
 private int[][] adjacencyMatrix;
 public Graph(int vertices) {
 this.vertices = vertices;
 this.adjacencyMatrix = new int[vertices][vertices]; }
 public void addEdge(int source, int destination, int weight) {
 adjacencyMatrix[source][destination] = weight; }
// Depth First Search traversal starting from a given vertex
 public void depthFirstSearch(int startVertex) {
 boolean[] visited = new boolean[vertices];
 Stack<Integer> stack = new Stack<>();
 // Mark the current node as visited and push it to the stack
 visited[startVertex] = true;
 stack.push(startVertex);
 System.out.println("DFS traversal starting from vertex " + startVertex + ":");
 while (!stack.isEmpty()) {
 // Pop a vertex from the stack and print it
 int currentVertex = stack.pop();
 System.out.print(currentVertex + " ");
 // Get all adjacent vertices of the popped vertex
 for (int i = 0; i < vertices; i++) {
 if (adjacencyMatrix[currentVertex][i] != 0 && !visited[i]) {
 visited[i] = true;
 stack.push(i);
 }
 }
 }
 System.out.println();
 }
 // Print the adjacency matrix
 public void printAdjMatrix() {
 System.out.println("Adjacency Matrix:");
 for (int i = 0; i < vertices; i++) {
 System.out.println(Arrays.toString(adjacencyMatrix[i]));
 }
 }
}
public class AdjMatrix {
 public static void main(String[] args) {
 // Create a graph and add edges
 Graph g = new Graph(5);
 g.addEdge(0, 1, 2); g.addEdge(0, 4, 5);
 g.addEdge(1, 2, 1); g.addEdge(1, 3, 4); g.addEdge(1, 4, 3);
 g.addEdge(2, 2, 7); g.addEdge(2, 4 , 9);
 g.addEdge(3, 4, 6);
 g.printAdjMatrix();
 g.depthFirstSearch(0); // DFS traversal starting from vertex 0
 }
}
